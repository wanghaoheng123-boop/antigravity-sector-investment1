# Copy to `.env.local` for local dev and add to Vercel / hosting env.

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of your deployment (e.g. http://localhost:3000 or https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# ── Optional: Bloomberg via self-hosted HTTP bridge (Terminal / blpapi / enterprise gateway)
# Next.js never talks to Bloomberg directly; it calls YOUR bridge. See README + scripts/bloomberg-bridge-example.py
BLOOMBERG_BRIDGE_URL=
# Shared secret your bridge checks on header X-Bridge-Secret (optional)
BLOOMBERG_BRIDGE_SECRET=
BLOOMBERG_BRIDGE_TIMEOUT_MS=4000
# Optional JSON map Yahoo ticker -> full Bloomberg security, e.g. {"BRK.B":"BRK/B US Equity"}
# (Used if you add server-side resolution that reads this env; bridge may also map.)
BLOOMBERG_TICKER_MAP=
