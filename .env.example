# ─── TradingAgents API ────────────────────────────────────────────────────────
# Required: at least one LLM provider key (uncomment / fill in)
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#GOOGLE_API_KEY=AIza...
#XAI_API_KEY=xai-...
#OPENROUTER_API_KEY=sk-or-...

# Optional: Alpha Vantage for alternative data vendor in TradingAgents
#ALPHA_VANTAGE_API_KEY=...

# ─── Next.js ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# Leave blank to use defaults (no auth = public read-only demo).

# Public URL of the deployed TradingAgents Python API (Vercel production). No trailing slash.
# Must be https:// in production (enforced). Local `npm run dev` uses http://127.0.0.1:3001 if unset.
#TRADING_AGENTS_BASE=https://your-app.up.railway.app
# Optional managed fallback backend for zero-setup users.
# Used only if TRADING_AGENTS_BASE is unset. Must be https:// in production.
#TRADING_AGENTS_FALLBACK_BASE=https://shared-tradingagents.your-domain.com

NEXTAUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Optional: Quant Lab "Feedback" button opens this URL (GitHub issue/discussion, form, etc.)
#NEXT_PUBLIC_QUANTAN_FEEDBACK_URL=https://github.com/your-org/your-repo/issues/new

# Optional: GitHub OAuth (enable sign-in)
#GITHUB_CLIENT_ID=Ov23...
#GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Bloomberg Bridge (optional) ──────────────────────────────────────────────
# Enable Bloomberg as an alternative data source for spot prices.
# Uncomment and fill in if you run a Bloomberg blpapi bridge:
#BLOOMBERG_BRIDGE_URL=http://localhost:8080
