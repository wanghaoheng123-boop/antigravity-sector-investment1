{
  "name": "quantan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "validate:data": "node scripts/validate-data-samples.mjs",
    "check:smoke": "node scripts/smoke-production.mjs",
    "check:smoke:extended": "node scripts/run-smoke-extended.mjs",
    "check:smoke:local": "node scripts/run-smoke-local.mjs",
    "check:smoke:local:extended": "node scripts/run-smoke-local-extended.mjs",
    "check:smoke:local:nosearch": "node scripts/run-smoke-local-nosearch.mjs",
    "check:smoke:local:extended:nosearch": "node scripts/run-smoke-local-extended-nosearch.mjs",
    "verify:logic": "node scripts/verify-core-logic.mjs",
    "verify:indicators": "node scripts/verify-indicator-math.mjs",
    "verify:btc": "node scripts/verify-btc-ohlc-sample.mjs",
    "diagnose:crypto": "node scripts/diagnose-crypto.mjs",
    "verify:data": "npm run verify:logic && npm run verify:indicators && npm run verify:btc",
    "check:all": "npm run verify:data && npm run validate:data && npm run check:smoke",
    "check:ci": "npm run verify:data && npm run check:smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "node scripts/benchmark-signals.mjs",
    "benchmark:enhanced": "npx tsx --tsconfig tsconfig.json scripts/benchmark-enhanced.ts",
    "optimize:grid": "npx tsx --tsconfig tsconfig.json scripts/optimize-grid.ts",
    "portfolio:backtest": "npx tsx --tsconfig tsconfig.json scripts/portfolio-backtest.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.8",
    "lightweight-charts": "^4.1.3",
    "lucide-react": "^0.395.0",
    "next": "^14.2.15",
    "next-auth": "^4.24.11",
    "react": "^18",
    "react-dom": "^18",
    "swr": "^2.2.5",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vercel": "^50.35.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "tsx": "^4.19.2"
  }
}
